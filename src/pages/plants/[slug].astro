---
import Layout from "../../layouts/Layout.astro"
import "@/styles/main.css"
import "@/styles/plant-detail.css"
import plantsData from "@/data/plants.json"

const detailLabels: Record<string, string> = {
    soil: "Suelo",
    substrate: "Sustrato",
    ph: "pH",
    spacing: "Espacio",
    depth: "Profundidad",
    season: "Época",
    harvest: "Cosecha",
    flowering: "Floración",
    humidity: "Humedad",
    ventilation: "Ventilación",
    water: "Agua",
    pot: "Maceta",
}

export async function getStaticPaths() {
    return plantsData.plants.map((plant) => ({
        params: { slug: plant.slug },
    }))
}

const { slug } = Astro.params
const plant = plantsData.plants.find((item) => item.slug === slug)

if (!plant) {
    throw new Error(`Planta con slug "${slug}" no encontrada`)
}

const careItems = [
    { label: "Riego", value: plant.care.watering, marker: "≈" },
    { label: "Luz", value: plant.care.light, marker: "☼" },
    { label: "Temperatura", value: plant.care.temperature, marker: "⌁" },
    { label: "Dificultad", value: plant.care.difficulty, marker: "↗" },
]

const detailEntries = Object.entries(plant.details)
---

<Layout title={`${plant.name} — Mis Plantas`}>
    <div class="back-navigation">
        <a href="/#plantas" class="back-link">← Volver a la colección</a>
    </div>

    <section class="plant-hero" aria-labelledby="plant-title">
        <div class="plant-hero-content">
            <figure class="plant-hero-image">
                <img
                    src={plant.image}
                    alt={plant.name}
                    fetchpriority="high"
                />
                <figcaption>Ficha de la colección</figcaption>
            </figure>

            <div class="plant-hero-info">
                <p class="eyebrow"><span aria-hidden="true"></span>{plant.care.difficulty}</p>
                <h1 id="plant-title">{plant.name}</h1>
                <p class="plant-description">{plant.description}</p>

                <section class="care-basics" aria-labelledby="care-title">
                    <div class="care-heading">
                        <p>Ritmo de cuidado</p>
                        <h2 id="care-title">Lo esencial, de un vistazo.</h2>
                    </div>
                    <dl class="care-grid">
                        {
                            careItems.map((item) => (
                                <div class="care-item">
                                    <dt><span aria-hidden="true">{item.marker}</span>{item.label}</dt>
                                    <dd>{item.value}</dd>
                                </div>
                            ))
                        }
                    </dl>
                </section>
            </div>
        </div>
    </section>

    <section class="plant-details" aria-labelledby="details-title">
        <div class="detail-section-heading">
            <p class="eyebrow"><span aria-hidden="true"></span>Notas de cultivo</p>
            <h2 id="details-title">La ficha completa.</h2>
        </div>

        <div class="details-grid">
            <article class="detail-card detail-card--conditions">
                <h3>Condiciones</h3>
                <dl class="conditions-list">
                    {
                        detailEntries.map(([key, value]) => (
                            <div>
                                <dt>{detailLabels[key] ?? key}</dt>
                                <dd>{value}</dd>
                            </div>
                        ))
                    }
                </dl>
            </article>

            <article class="detail-card detail-card--problems">
                <h3>Si notas…</h3>
                <ul class="problem-list">
                    {
                        plant.problems.map((problem) => (
                            <li>
                                <strong>{problem.issue}</strong>
                                <span>{problem.solution}</span>
                            </li>
                        ))
                    }
                </ul>
            </article>

            <article class="detail-card detail-card--tips">
                <h3>Rutina</h3>
                <ol class="routine-list">
                    {plant.tips.map((tip) => <li>{tip}</li>)}
                </ol>
            </article>
        </div>
    </section>

    <section class="plant-gallery" aria-labelledby="gallery-title">
        <div class="gallery-heading">
            <p class="eyebrow"><span aria-hidden="true"></span>Registro visual</p>
            <h2 id="gallery-title">La planta, vista de cerca.</h2>
        </div>
        <div class="gallery-grid">
            {
                plant.gallery.map((img, index) => (
                    <figure class={`gallery-item gallery-item--${index + 1}`}>
                        <img
                            src={img}
                            alt={`Vista ${index + 1} de ${plant.name}`}
                            loading="lazy"
                            decoding="async"
                        />
                        <figcaption>{String(index + 1).padStart(2, "0")} / {String(plant.gallery.length).padStart(2, "0")}</figcaption>
                    </figure>
                ))
            }
        </div>
    </section>
</Layout>
